# =============================================================================
# Prefer the interactive helper (on the host as root):
#   bash /root/proxmox-setup/scripts/configure-proxmox-network-env.sh
# Or copy this file to /etc/default/proxmox-network.env and edit by hand.
# Then:  bash /root/proxmox-setup/scripts/setup-proxmox-network.sh --apply
# =============================================================================
#
# AUTO-GENERATED by scripts/generate-network-env-adapters.sh from
# docs/proxmox/config/network-env-schema.yaml. Do not edit manually.
#

# Wi-Fi interface name (e.g. wlp2s0)
WIFI=

# Default gateway IP address
GW=

# Proxmox management IP/CIDR (e.g. 10.0.0.5/24)
VMBR_IP=

# Home Wi-Fi SSID
WPA_HOME_SSID=

# Home Wi-Fi password (use single quotes in env file)
# SENSITIVE — use single quotes to avoid shell expansion
# No newlines in the value.
WPA_HOME_PSK=''

# USB Ethernet interface name (e.g. enx00e04c123456); empty if not yet plugged in
ETH_USB=

# Proxmox bridge name
VMBR=vmbr0

# WPA country code
WPA_COUNTRY=US

# Home Wi-Fi priority (higher = preferred)
WPA_HOME_PRIORITY=10

# Phone hotspot SSID; optional
WPA_HOTSPOT_SSID=

# Phone hotspot password; optional, use single quotes in env file
# SENSITIVE — use single quotes to avoid shell expansion
# No newlines in the value.
WPA_HOTSPOT_PSK=''

# Hotspot priority
WPA_HOTSPOT_PRIORITY=5
