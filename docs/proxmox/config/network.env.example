# =============================================================================
# Prefer the interactive helper (on the host as root):
#   bash /root/proxmox-setup/scripts/configure-proxmox-network-env.sh
# Or copy this file to /etc/default/proxmox-network.env and edit by hand.
# Then:  bash /root/proxmox-setup/scripts/setup-proxmox-network.sh --apply
# =============================================================================

# --- Interfaces (leave empty to auto-detect first enx* and wlp*) ---
ETH_USB=
WIFI=

# --- Your LAN (change to match your router) ---
# configure-proxmox-network-env.sh detects GW from the default route and
# suggests VMBR_IP on the same subnet (e.g. GW 192.168.50.1 → 192.168.50.130/24).
GW=192.168.1.1
VMBR_IP=192.168.1.130/24

# --- Wi-Fi (required) ---
WPA_COUNTRY=US
WPA_HOME_SSID=your_home_ssid
# Use quotes if you edit by hand (spaces/symbols). No newlines in the password.
WPA_HOME_PSK='your_home_password'
WPA_HOME_PRIORITY=10

# Optional hotspot (leave SSID empty to skip)
WPA_HOTSPOT_SSID=
WPA_HOTSPOT_PSK=
WPA_HOTSPOT_PRIORITY=5
