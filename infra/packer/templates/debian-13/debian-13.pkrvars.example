# ---------------------------------------------------------------------------
# Packer variable overrides for Debian 13 template
#
# Copy this file to debian-13.pkrvars.hcl (not tracked by git), fill in your
# values, and run:
#
#   cd infra/packer/templates/debian-13
#   packer init .
#   packer validate -var-file=debian-13.pkrvars.hcl .
#   packer build    -var-file=debian-13.pkrvars.hcl .
#
# In CI, these values are passed via PKR_VAR_ environment variables from
# GitHub repository variables and secrets (see .github/workflows/packer-build.yml).
# ---------------------------------------------------------------------------

# ---- Proxmox connection (mirrors proxmox-connection module) ----
# Connection variables are defined in connection-vars.pkr.hcl (generated from schema).
# Override them here or via PKR_VAR_ environment variables.
proxmox_endpoint     = "https://<proxmox-tailnet-host>:8006"
proxmox_api_token    = "USER@REALM!TOKENID=TOKEN_SECRET"
proxmox_node_name    = "pve"
proxmox_insecure_tls = true

# Template identity is supplied by the catalog resolver.
# ---- Storage ----
storage_pool            = "local-lvm"
cloud_init_storage_pool = null # defaults to storage_pool when null

# ---- SSH ----
ssh_password = "packer" # temporary build-only password; account is locked before templating
# root_password  = "packer"   # Only used during automated install; root is locked after provisioning
ssh_public_keys = [
  "ssh-ed25519 REPLACE_WITH_PUBLIC_KEY_ONLY autolab@example"
]

# ---- Network ----
network_bridge = "vmbr0"

# ---- Bastion / SSH relay ----
ssh_bastion_host             = "<proxmox-tailnet-host>"
ssh_bastion_username         = "root"
ssh_bastion_private_key_file = "~/.ssh/pve_ci_key"
